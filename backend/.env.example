# ═══ Nanoneuron CRM — Railway Environment Variables ═══
# Copy this to .env and fill in your values.
# Set all of these in Railway → Project → Variables

# PostgreSQL (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE

# JWT — generate a random 64-char secret
JWT_SECRET=replace-with-64-char-random-secret

# Anthropic Claude (optional — AI email drafting)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — your Cloudflare Pages domain
CORS_ORIGINS=["https://nanoneuron.ai","https://www.nanoneuron.ai"]

# Credits
FREE_CREDITS=10
CREDIT_COST_PER_LEAD=1

# SMTP (optional — for direct email sending)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587

# Bank — India (NEFT/RTGS/IMPS/UPI)
BANK_NAME=Axis Bank
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_HOLDER=Nanoneuron Services
BANK_IFSC=

# SWIFT USD
SWIFT_USD_BENEFICIARY=Nanoneuron Services
SWIFT_USD_ACCOUNT=
SWIFT_USD_BANK_SWIFT=AXISINBBA02
SWIFT_USD_CORRESPONDENT=JP Morgan Chase Bank New York
SWIFT_USD_CORRESPONDENT_SWIFT=CHASUS33
SWIFT_USD_NOSTRO=
SWIFT_USD_IBAN=

# SWIFT GBP
SWIFT_GBP_CORRESPONDENT=JP Morgan Chase London
SWIFT_GBP_CORRESPONDENT_SWIFT=CHASGB2L
SWIFT_GBP_NOSTRO=
SWIFT_GBP_IBAN=

# SWIFT EUR
SWIFT_EUR_CORRESPONDENT=JP Morgan Chase Frankfurt
SWIFT_EUR_CORRESPONDENT_SWIFT=CHASDEFX
SWIFT_EUR_NOSTRO=
SWIFT_EUR_IBAN=
