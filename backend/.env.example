# ─── Required ──────────────────────────────────────────────────────
# Railway auto-sets DATABASE_URL when you add a PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# ─── Optional but recommended ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HUNTER_API_KEY=

# Add your Cloudflare Pages URL after first deploy
EXTRA_CORS_ORIGINS=https://nanoneuron-mvp.pages.dev,https://nanoneuron.ai

# ─── Founder dashboard (double-lock) ──────────────────────────────
FOUNDER_EMAIL=your@email.com
FOUNDER_SECRET=replace-with-random-secret

# ─── Invoice / Company ─────────────────────────────────────────────
COMPANY_NAME=Nanoneuron Services
COMPANY_GSTIN=27EPIPM6974Q1Z0
COMPANY_STATE=Maharashtra
COMPANY_ADDRESS=Your registered address

# ─── Email (optional) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@email.com
SMTP_PASS=app-password
SMTP_PORT=587

# ─── Bank ─────────────────────────────────────────────────────────
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_HOLDER=
BANK_IFSC=
SWIFT_BENEFICIARY_NAME=
SWIFT_BENEFICIARY_ACCOUNT=
